# ZeroQCM — Environment Variables
# Copy this file to .env.local and fill in the values.

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key  # Server-side only!

# ── GitHub Copilot Internal API ───────────────────────────────────────────────
# OAuth tokens are stored in the ai_tokens table in Supabase (managed via Admin → AI Tokens)
# Optionally provide a fallback env-var token:
GITHUB_COPILOT_OAUTH_TOKEN=ghu_your_oauth_token_here

# GitHub Copilot Device Flow client ID (for acquiring OAuth tokens via Admin)
GITHUB_COPILOT_CLIENT_ID=Iv1.b507a08c87ecfe98

# ── GitHub Models (Legacy — now using Copilot internal API) ──────────────────
# Keep for regen-explanations route fallback
GITHUB_MODELS_TOKEN=ghp_your_personal_access_token

# ── Cron Protection ───────────────────────────────────────────────────────────
# Used by /api/sync (called daily by Vercel Cron at 02:00 UTC+1)
# Must match the Authorization: Bearer header in Vercel cron config
CRON_SECRET=your-random-secure-cron-secret

# ── App URL ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://zeroqcm.me
